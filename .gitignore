apps/admin-web/src/typings/elegant-router.d.ts
apps/admin-web/src/router/elegant/*
!apps/admin-web/src/router/elegant/marketing-cutover.ts

# Backend OpenAPI 输出（main.ts 每次启动写入；generate-types 依赖，需先运行 backend）
apps/backend/public/openApi.json
apps/backend/public/.openapi-contract-max-mtime

