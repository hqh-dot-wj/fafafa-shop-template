{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "target": "ESNext",
    "paths": {
      "@/*": ["./src/*"],
      "@img/*": ["./src/static/*"],
      "wot-design-uni/components/*": ["./src/types/wot-design-uni-component-shim.d.ts"],
      "wot-design-uni/components/common/*": ["./src/types/wot-design-uni-module-shim.d.ts"],
      "wot-design-uni/components/composables/*": ["./src/types/wot-design-uni-module-shim.d.ts"]
    },
    "types": [
      "@dcloudio/types",
      "@uni-helper/uni-types",
      "@uni-helper/vite-plugin-uni-pages",
      "miniprogram-api-typings",
      "z-paging/types",
      "./src/types/async-component.d.ts",
      "./src/types/async-import.d.ts",
      "./src/typings.d.ts",
      "./src/types/wot-design-uni-global.d.ts"
    ],
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "declaration": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.jsx",
    "src/**/*.vue",
    "src/**/*.json"
  ],
  "exclude": ["node_modules", "dist"],
  "vueCompilerOptions": {
    "strictTemplates": false
  }
}
