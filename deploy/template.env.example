# =============================================================================
# fafafa.app 模板部署 - 环境变量说明（不直接被加载）
# =============================================================================
# 本文件描述本仓库作为 fafafa.app 商城模板被部署时所需的所有环境变量。
# - 平台注入：由 fafafa Provisioning Engine 在 GitLab Pipeline trigger 时传入
# - 模板配置：在 fafafa 后台「模板管理 · 部署方案」的 ProductDeployTemplate 配置
# - CI Secrets：在 GitLab 仓库 Settings → CI/CD → Variables 配置（不入库）
#
# 与 deploy/env.production.example 的区别：
#   env.production.example 用于「手工部署」（docker-compose.prod.yml），含内置 postgres
#   template.env.example   用于「fafafa 自动化部署」（docker-compose.tpl.yml），外部 DB
# =============================================================================

# -----------------------------------------------------------------------------
# 一、fafafa Provisioning Engine 自动注入（参考 fafafa.app variable-builder.ts）
# -----------------------------------------------------------------------------

# 订单/任务标识
JOB_NO=job_20260623_xxxxxx                          # 本次开通任务编号（callback / deploy-result 必传）
INSTANCE_ID=ws_xxxxxxxxxxxxxxx                      # WebsiteService _id（未生成时为 pending_${ORDER_NO}）
ORDER_NO=ORD2026062300001                           # 用户订单号
TEMPLATE_ID=                                        # Template._id（MongoDB）
PRODUCT_CODE=mall-template                          # 产品 code（如 car-rental / mall）

# 域名与机房
DOMAIN=shop.zhangsan.com                            # 用户绑定的域名（task-nginx 反代依据）
REGION=cn-east                                      # 用户选择的机房 / 地区
SERVER_IP=1.2.3.4                                   # 由 fafafa ServerInventory 分配
PURPOSE=                                            # 业务用途标记（fafafa 内部分类）

# Docker Compose 订单隔离
PROJECT_NAMES=mall-template-ord2026062300001        # buildOrderDeploySlug(templateCode, orderNo)，容器名前缀
EXTERNAL_NETWORK_NAME=shared_net                    # task-nginx 反代用的共享 docker network
WEB_PORTS=80                                        # 对外端口（task-nginx upstream 用）

# SSH 部署目标
DEPLOY_HOSTS=1.2.3.4                                # SSH 目标主机（与 SERVER_IP 通常同值）
DEPLOY_USERS=root                                   # SSH 用户
DEPLOY_PATHS=/opt/mall-template-ord2026062300001    # 部署目录（与 PROJECT_NAMES 对齐）
DEPLOY_PORTS=22                                     # SSH 端口

# fafafa 平台回调
CALLBACK_URL=https://fafafa.example.com/api/web/provisioning/callback
CALLBACK_TOKEN=cb_xxxxxxxxxxxxxxxxxxxx              # 每 Job 一次性 Bearer Token
DB_CREDENTIAL_REF=cred_job_20260623_xxxxxx          # 用此引用调 /credentials/exchange 换 DB 密码

# 外部 DB（fafafa needDatabase=true 时分配；本仓库 PostgreSQL）
DB_HOST=10.0.0.5
DB_PORT=5432
DB_NAME=mall_ord2026062300001
DB_USER=mall_ord2026062300001_app
# DB_PASSWORD 不通过 trigger 明传，由 exchange-credential.sh 实时换取

# 镜像
REGISTRY_NAMESPACE=registry.gitlab.example.com/templates/mall-template
IMAGE_TAG=                                          # 默认走本仓库 CI_COMMIT_SHORT_SHA

# -----------------------------------------------------------------------------
# 二、ProductDeployTemplate 配置（fafafa 后台 · 模板管理 · 部署方案）
# -----------------------------------------------------------------------------
# 这些是模板维度而非订单维度的配置，建议在 ProductDeployTemplate 一次配齐：
#
#   driver=gitlab
#   gitlabProjectId=<本仓库 GitLab Project ID>
#   gitlabRef=main
#   pipelineTriggerTokenKey=GITLAB_TRIGGER_MALL_TEMPLATE  (指向 fafafa API 的环境变量名)
#   imageName=registry.gitlab.example.com/templates/mall-template
#   needDatabase=true
#   databaseType=pg
#   requiredVariables=[
#     JOB_NO, INSTANCE_ID, ORDER_NO, TEMPLATE_ID, PRODUCT_CODE,
#     DOMAIN, REGION, SERVER_IP, PURPOSE,
#     PROJECT_NAMES, EXTERNAL_NETWORK_NAME, WEB_PORTS,
#     DEPLOY_HOSTS, DEPLOY_USERS, DEPLOY_PATHS, DEPLOY_PORTS,
#     CALLBACK_URL, CALLBACK_TOKEN, DB_CREDENTIAL_REF, DB_PORT,
#     DB_HOST, DB_NAME, DB_USER,
#     TEMPLATE_BRAND_COMPANY_NAME, TEMPLATE_ADMIN_USERNAME, TEMPLATE_ADMIN_PASSWORD,
#     JWT_SECRET, REDIS_PASSWORD
#   ]

# -----------------------------------------------------------------------------
# 三、GitLab CI Secrets（仓库 Settings → CI/CD → Variables，masked=true）
# -----------------------------------------------------------------------------

SSH_PRIVATE_KEY=                                    # CI runner SSH 到 SERVER_IP 的私钥（PEM 整体内容）
CI_REGISTRY_USER=                                   # 镜像仓库登录用户（GitLab 内置变量，一般无需手动配）
CI_REGISTRY_PASSWORD=                               # 同上
CI_REGISTRY=                                        # 同上

# -----------------------------------------------------------------------------
# 四、品牌 / 管理员（模板每次部署的差异化配置）
# -----------------------------------------------------------------------------
# 这些字段决定每个客户实例的品牌外观与初始管理员账号；
# 由 fafafa 在用户填写 DeployRequest 表单后，作为 Pipeline 变量传入。
# apps/backend/prisma/seeds/00-platform/apply-template-branding.ts 在 seed 末尾读取并覆写。

TEMPLATE_BRAND_COMPANY_NAME=张三的零售店                # 必填，写入 sys_tenant.company_name
TEMPLATE_BRAND_LOGO_URL=                              # 可选，写入 sys_tenant（如后续扩展 logo 字段）
TEMPLATE_BRAND_CONTACT_PHONE=                         # 可选，写入 sys_tenant.contact_phone
# TEMPLATE_BRAND_DOMAIN 由脚本从 DOMAIN 自动推断（无需重复声明）

TEMPLATE_ADMIN_USERNAME=zhangsan                      # 必填，覆写默认 admin 账号
TEMPLATE_ADMIN_PASSWORD=                              # 必填，明文密码（bcrypt 后写入 sys_user.password）

# -----------------------------------------------------------------------------
# 五、应用基础密钥（每个实例独立生成，不可复用）
# -----------------------------------------------------------------------------

JWT_SECRET=                                           # >= 32 chars，建议 openssl rand -base64 48
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

REDIS_PASSWORD=                                       # 内置 Redis 容器密码（每实例独立）
REDIS_DB=2

# RSA 密钥对（CRYPTO_ENABLED=true 时必填；本地可 pnpm --filter @apps/backend generate:keys 生成）
CRYPTO_ENABLED=true
CRYPTO_RSA_PUBLIC_KEY=
CRYPTO_RSA_PRIVATE_KEY=

# 营销活动签名密钥
MARKETING_ACTIVITY_TOKEN_SECRET_PRIMARY=

# 文件上传：本地落盘到 docker volume；FILE_DOMAIN 由 compose 模板从 DOMAIN 推断
FILE_IS_LOCAL=true
