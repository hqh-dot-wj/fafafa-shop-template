/// 统一错误事件（前端、后端、步骤失败的排查入口）
model SysErrorEvent {
  id               String   @id @default(cuid())
  app              String   @db.VarChar(32)
  env              String?  @db.VarChar(32)
  level            String   @db.VarChar(16)
  requestId        String?  @map("request_id") @db.VarChar(100)
  traceId          String?  @map("trace_id") @db.VarChar(100)
  errorId          String   @unique @map("error_id") @db.VarChar(100)
  tenantId         String?  @map("tenant_id") @db.VarChar(20)
  userId           String?  @map("user_id") @db.VarChar(64)
  route            String?  @db.VarChar(500)
  method           String?  @db.VarChar(16)
  module           String?  @db.VarChar(100)
  operationCode    String?  @map("operation_code") @db.VarChar(120)
  stepCode         String?  @map("step_code") @db.VarChar(160)
  stepName         String?  @map("step_name") @db.VarChar(120)
  errorCode        String   @map("error_code") @db.VarChar(100)
  safeMessage      String   @map("safe_message") @db.VarChar(500)
  technicalMessage String?  @map("technical_message") @db.Text
  stack            String?  @db.Text
  cause            String?  @db.Text
  metadata         Json?
  durationMs       Int?     @map("duration_ms")
  source           String?  @db.VarChar(32)
  createTime       DateTime @default(now()) @map("create_time")

  @@index([traceId])
  @@index([requestId])
  @@index([errorCode, createTime])
  @@index([operationCode, stepCode, createTime])
  @@index([tenantId, createTime])
  @@map("sys_error_event")
}

/// 业务步骤事件（关键流程每一步成功/失败/耗时）
