    "@swc/cli": "0.1.62",
    "@swc/core": "1.3.86",
    "@types/archiver": "catalog:",
    "@types/csurf": "^1.11.2",
    "@types/express": "^4.17.17",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "catalog:",
