# 变量必须以 VITE_ 为前缀才能暴露给外部读取
NODE_ENV = 'development'
# 是否去除console 和 debugger
VITE_DELETE_CONSOLE = false
# 是否开启sourcemap
VITE_SHOW_SOURCEMAP = false

# 后台请求地址
# VITE_SERVER_BASEURL = 'https://dev.xxx.com'

# H5 本地开发：无浏览器定位时模拟超级租户（tenant-id=000000），仅 dev:h5 生效
VITE_DEV_MOCK_LOCATION = true
# VITE_DEV_MOCK_TENANT_ID = 000000
# VITE_DEV_MOCK_COMPANY_NAME = 湖南科技有限公司
# VITE_DEV_MOCK_LAT = 28.228209
# VITE_DEV_MOCK_LNG = 112.938814
