{
  "name": "nest-admin-soybean-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.5.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.5.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@apps/backend",
    "dev:admin": "turbo run dev --filter=@apps/admin-web",
    "dev:c-web": "turbo run dev --filter=@apps/c-web",
    "dev:h5": "pnpm dev:mp",
    "dev:mp": "turbo run dev --filter=@apps/miniapp-client",
    "check:backend": "turbo run lint typecheck --filter=@apps/backend",
    "check:admin": "turbo run lint typecheck --filter=@apps/admin-web",
    "check:c-web": "turbo run lint typecheck --filter=@apps/c-web",
    "check:h5": "turbo run lint typecheck --filter=@apps/miniapp-client",
    "check:slice": "node scripts/tasks/changed-files.mjs check-slice",
    "ci:local": "pnpm verify-monorepo && pnpm verify:quality-gates && pnpm verify:admin-view-types && pnpm lint && pnpm typecheck",
    "ci:local:backend": "pnpm --filter @apps/backend prisma:generate && pnpm build:backend && pnpm contracts:check",
    "fix:changed": "node scripts/tasks/changed-files.mjs fix",
    "build": "turbo run build",
    "build:backend": "turbo run build --filter=@apps/backend",
    "build:admin": "turbo run build --filter=@apps/admin-web",
    "build:c-web": "turbo run build --filter=@apps/c-web",
    "build:h5": "pnpm build:mp",
    "build:mp": "turbo run build --filter=@apps/miniapp-client",
    "contracts:generate": "turbo run generate-types --filter=@libs/common-types",
    "contracts:check": "pnpm contracts:generate && pnpm typecheck:admin && pnpm typecheck:c-web",
    "generate-types": "pnpm contracts:generate",
    "harness:doctor": "node scripts/harness-doctor.mjs",
    "harness:docs": "node scripts/harness-doctor.mjs --docs",
    "harness:smoke": "node scripts/harness-smoke.mjs",
    "harness:smoke:admin": "node scripts/harness-smoke.mjs --admin",
    "harness:smoke:backend": "node scripts/harness-smoke.mjs --backend",
    "harness:smoke:h5": "node scripts/harness-smoke.mjs --h5",
    "harness:maps": "node scripts/tasks/generate-project-maps.mjs",
    "harness:manifest": "node scripts/harness-manifest.mjs",
    "harness:manifest:check": "node scripts/harness-manifest.mjs --check",
    "eval:phase": "node scripts/eval-phase.mjs",
    "verify:pr-slice": "node scripts/tasks/verify-pr-slice.mjs",
    "harness:plan-stale": "node scripts/check-exec-plan-stale.mjs",
    "harness:impact": "node scripts/tasks/domain-impact.mjs",
    "harness:cutover-due": "node scripts/tasks/cutover-due.mjs",
    "pr:land": "node scripts/tasks/pr-land.mjs",
    "lint": "pnpm lint:backend && pnpm lint:admin && pnpm lint:c-web",
    "lint:backend": "turbo run lint --filter=@apps/backend",
    "lint:admin": "turbo run lint --filter=@apps/admin-web",
    "lint:c-web": "turbo run lint --filter=@apps/c-web",
    "lint:h5": "turbo run lint --filter=@apps/miniapp-client",
    "typecheck": "pnpm typecheck:backend && pnpm typecheck:admin && pnpm typecheck:c-web",
    "typecheck:backend": "turbo run typecheck --filter=@apps/backend",
    "typecheck:admin": "turbo run typecheck --filter=@apps/admin-web",
    "typecheck:c-web": "turbo run typecheck --filter=@apps/c-web",
    "typecheck:h5": "turbo run typecheck --filter=@apps/miniapp-client",
    "test": "pnpm test:scripts && turbo run test",
    "test:backend": "turbo run test --filter=@apps/backend",
    "test:admin": "turbo run test --filter=@apps/admin-web",
    "test:scripts": "node scripts/tasks/test-scripts.mjs",
    "verify:agents-consistency": "node scripts/tasks/check-agents-consistency.mjs",
    "verify:openapi-fresh": "node scripts/tasks/check-openapi-fresh.mjs",
    "verify:forwardref-reason": "node scripts/check-forwardref-reason.mjs",
    "verify:spec-drift": "node scripts/check-spec-drift.mjs --branch",
    "verify:dict-governance": "node scripts/check-dict-governance.mjs",
    "verify:repo-artifacts": "node scripts/check-repo-artifacts.mjs --all",
    "verify:repo-artifacts:staged": "node scripts/check-repo-artifacts.mjs --staged",
    "verify:contract-exceptions": "node scripts/check-contract-exceptions.mjs",
    "report:quality-gates": "node scripts/check-quality-gates.mjs --all",
    "report:strict": "node scripts/tasks/strict-report.mjs",
    "verify:quality-gates": "node scripts/check-quality-gates.mjs --branch",
    "verify:quality-gates:staged": "node scripts/check-quality-gates.mjs --staged",
    "verify:admin-view-types": "node scripts/check-admin-view-types.mjs --branch",
    "verify:admin-view-types:staged": "node scripts/check-admin-view-types.mjs --staged",
    "verify": "pnpm verify-monorepo && pnpm verify:scripts && pnpm verify:openapi-fresh && pnpm contracts:check && pnpm lint && pnpm verify:quality-gates && pnpm verify:admin-view-types && pnpm verify:repo-artifacts && pnpm verify:contract-exceptions && pnpm typecheck && pnpm test",
    "verify:pre-push": "pnpm verify-monorepo && pnpm verify:scripts && pnpm verify:openapi-fresh && pnpm contracts:check && pnpm lint && pnpm verify:quality-gates && pnpm verify:admin-view-types && pnpm verify:repo-artifacts && pnpm verify:contract-exceptions && pnpm test:scripts",
    "verify:pre-push:full": "pnpm verify:pre-push",
    "verify-monorepo": "node scripts/verify-monorepo.mjs",
    "verify:scripts": "node scripts/tasks/package-scripts-governance.mjs",
    "prepare": "simple-git-hooks",
    "commitlint": "commitlint"
  },
  "simple-git-hooks": {
    "commit-msg": "node scripts/check-commit-message.mjs $1",
    "pre-commit": "pnpm lint-staged && pnpm verify:quality-gates:staged && pnpm verify:admin-view-types:staged",
    "pre-push": "pnpm verify:pre-push"
  },
  "lint-staged": {
    "**/*.{cjs,css,html,js,json,jsonc,jsx,less,md,mjs,sass,scss,ts,tsx,vue,yaml,yml}": [
      "node scripts/tasks/changed-files.mjs fix --staged"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@eslint/js": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^4.5.3",
    "lint-staged": "catalog:",
    "simple-git-hooks": "catalog:",
    "turbo": "^2.3.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "unconfig": "7.4.2",
      "string-width": "4.2.3",
      "bin-wrapper": "npm:bin-wrapper-china",
      "cron": "3.2.1"
    }
  }
}
