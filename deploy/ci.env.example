# 复制为 deploy/ci.env 并填写（勿提交 deploy/ci.env）
# GitHub Actions deploy 工作流会 source 此文件（非敏感项可放仓库；密码放服务器 .env 或 GitHub Secrets）
#
# deploy/ 目录结构：
#   docker-compose.prod.yml   生产 Compose
#   docker/*.Dockerfile       镜像构建（上下文为仓库根）
#   nginx/*.conf              网关子路径路由（/ /h5/ /admin/ /api/）
#   sites/landing/            宣传页纯静态（打进 landing 镜像，与 .env 无关）
#   scripts/remote_deploy.sh  服务器滚动部署
#   scripts/cleanup-images.sh 镜像清理
#   ci.env.example            CI 部署目标（本文件）
#   env.production.example    服务器 .env 模板（主要给 api/DB/OSS）

# ---------- 部署目标（逗号分隔可多机）----------
DEPLOY_HOSTS=your-ecs-public-ip
DEPLOY_USERS=ubuntu
DEPLOY_PORTS=22
DEPLOY_PATHS=/opt/nest-admin
PROJECT_NAMES=nest-admin

# 对外 HTTP 端口（映射到 gateway）
HTTP_PORT=80

# ---------- 镜像仓库（须小写）----------
# 示例：ghcr.io/your-github-user/nest-admin-soybean
REGISTRY_NAMESPACE=ghcr.io/your-github-user/nest-admin-soybean

# ---------- 部署选项 ----------
# 日常增量：migrate deploy（与 RUN_DB_RESET 互斥，清库时设 RUN_MIGRATE=false）
RUN_MIGRATE=true

# 一次性 Path A 全量对齐（清库 + 70 条 migration + 漂移列；与本地 migrate reset 一致）
# 用法（仅 dev/测试 ECS，会删库）：RUN_MIGRATE=false RUN_DB_RESET=true RUN_HUNAN_SEED=true
# 对齐成功后务必改回：RUN_DB_RESET=false RUN_HUNAN_SEED=false RUN_MIGRATE=true
RUN_DB_RESET=false

# 湖南完整演示种子（商品/营销/拼课/场景）；需与 RUN_DB_RESET 同开做首次灌库
RUN_HUNAN_SEED=false

# 补首页 Tab 场景 + H5 联调账号（幂等，不清库）
RUN_H5_SUPPLEMENT=false

# 首次部署：平台基础数据 + admin（admin/admin123，上线后请改密）；有 RUN_HUNAN_SEED 时保持 false
RUN_BOOTSTRAP=false
# 仅 play_definition 最小 SQL（不能单独用于首次登录）；日常部署保持 false
RUN_SEED=false

# 部署后是否清理悬空 Docker 镜像
RUN_IMAGE_PRUNE=true

# Compose 网络名
COMPOSE_NETWORK_NAME=nest_admin_net
