{
  "name": "@apps/backend",
  "version": "2.0.0",
  "description": "Nest-Admin-Soybean 后端服务，基于 NestJS + Prisma 构建的企业级后台管理系统",
  "author": "hqh-dot-wj",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "cross-env NODE_ENV=development nest build --type-check --config nest-cli.build.json",
    "build:dev": "cross-env NODE_ENV=development nest build --type-check --config nest-cli.build.json",
    "build:test": "cross-env NODE_ENV=test nest build --type-check --config nest-cli.build.json",
    "build:prod": "cross-env NODE_ENV=production nest build --type-check --config nest-cli.build.json",
    "dev": "cross-env NODE_ENV=development nest start --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:test": "cross-env NODE_ENV=test nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "pnpm test:unit",
    "test:unit": "cross-env NODE_ENV=test jest",
    "test:integration": "cross-env NODE_ENV=test jest --config ./test/jest-integration.config.js --runInBand",
    "test:contract": "cross-env NODE_ENV=test jest --config ./test/jest-integration.config.js --testPathPattern=contract --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_ENV=test jest --config ./test/jest-e2e.json",
    "test:e2e:tenant-000000-keep": "cross-env NODE_ENV=test E2E_SKIP_CLEANUP=1 jest --config ./test/jest-e2e.json tenant-000000-marketing-distribution.e2e-spec.ts --runInBand",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test:finance": "jest --testPathPattern=finance",
    "test:finance:watch": "jest --testPathPattern=finance --watch",
    "test:finance:cov": "jest --testPathPattern=finance --coverage",
    "test:commission": "jest commission.service.spec",
    "test:wallet": "jest wallet.service.spec",
    "test:withdrawal": "jest withdrawal.service.spec",
    "test:settlement": "jest settlement.scheduler.spec",
    "prisma:generate": "prisma generate --schema prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma && ts-node prisma/seeds/08-campaign-cutover/run.ts",
    "prisma:seed:prod-bootstrap": "ts-node --transpile-only --project prisma/tsconfig.seed.json prisma/seeds/run-prod-bootstrap.ts",
    "prisma:seed:bootstrap-hunan": "ts-node --transpile-only -r tsconfig-paths/register prisma/seeds/run-bootstrap-then-hunan-overrides.ts",
    "prisma:seed:reset-hunan-skeleton": "prisma db push --schema prisma --force-reset --accept-data-loss && ts-node --transpile-only -r tsconfig-paths/register prisma/seeds/run-bootstrap-then-hunan-overrides.ts && pnpm redis:flush",
    "prisma:reset-super-menus": "ts-node scripts/reset-super-tenant-menus.ts",
    "prisma:ensure-audit-menus": "ts-node scripts/ensure-audit-menus.ts",
    "prisma:clear-business": "ts-node prisma/seeds/reset/clear-business-data.ts",
    "prisma:reset": "pnpm prisma:seed:reset-hunan-skeleton",
    "fulfillment:backfill": "ts-node -r tsconfig-paths/register scripts/data/backfill-fulfillment-orders.ts",
    "redis:flush": "docker exec nest-admin-redis redis-cli -a 123456 -n 2 FLUSHDB",
    "scan:tenant-prisma-reads": "node scripts/scan-tenant-prisma-reads.mjs",
    "generate:keys": "node scripts/generate-rsa-keys.cjs",
    "deploy:prod": "node scripts/deploy/deploy.cjs prod",
    "deploy:test": "node scripts/deploy/deploy.cjs test",
    "deploy:dev": "node scripts/deploy/deploy.cjs dev",
    "test:aliyun-sms": "ts-node -r tsconfig-paths/register scripts/test-aliyun-sms.ts",
    "seed:sync-tenant-demo": "ts-node scripts/seed/sync-tenant-demo-data.ts",
    "seed:upsert-dev-h5-member": "ts-node scripts/seed/upsert-dev-h5-member.ts",
    "check:menu-orphans": "ts-node -r tsconfig-paths/register scripts/check-sys-menu-orphans.ts",
    "ledger:marketing-runtime": "ts-node -r tsconfig-paths/register scripts/print-marketing-runtime-ledger.ts",
    "verify:lbs": "ts-node -r tsconfig-paths/register scripts/verify/verify-lbs.ts",
    "loadtest:marketing-scene-smoke": "k6 run scripts/loadtests/marketing-scene-smoke.k6.js",
    "loadtest:client-product-list": "k6 run scripts/loadtests/client-product-list-spike.k6.js",
    "loadtest:admin-product-list": "k6 run scripts/loadtests/admin-store-product-list-spike.k6.js",
    "loadtest:mixed-read-smoke": "k6 run scripts/loadtests/mixed-read-smoke.k6.js",
    "loadtest:store-product-import-excel": "k6 run scripts/loadtests/store-product-import-excel-spike.k6.js",
    "loadtest:client-product-list:matrix": "node scripts/loadtests/run-product-query-load-matrix.mjs",
    "capacity:product-query": "node scripts/loadtests/product-query-capacity-estimator.mjs",
    "verify:rate-limit-alert-rules": "node scripts/monitoring/validate-rate-limit-alert-rules.mjs",
    "verify:rate-limit-alert-rules:dev": "cross-env RATE_LIMIT_ALERT_ENV=dev node scripts/monitoring/validate-rate-limit-alert-rules.mjs",
    "verify:rate-limit-alert-rules:staging": "cross-env RATE_LIMIT_ALERT_ENV=staging node scripts/monitoring/validate-rate-limit-alert-rules.mjs",
    "verify:rate-limit-alert-rules:prod": "cross-env RATE_LIMIT_ALERT_ENV=prod node scripts/monitoring/validate-rate-limit-alert-rules.mjs"
  },
  "prisma": {
    "schema": "prisma",
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "dependencies": {
    "@alicloud/credentials": "^2.4.4",
    "@alicloud/dypnsapi20170525": "^2.0.0",
