# ========================================
# 纯环境变量配置示例（复制为 .env 后按需修改）
# ========================================

# 运行环境：development | test | production
NODE_ENV=development

# PostgreSQL：Prisma CLI 与 Nest 运行时共用（见 apps/backend/AGENTS.md「数据库与 Prisma」）
DATABASE_URL="postgresql://postgres:123456@127.0.0.1:5432/nest-admin-soybean?schema=public&sslmode=disable"
# Prisma 连接池（可按实例规格和并发量调优）
# PRISMA_CONNECTION_LIMIT=10
# PRISMA_POOL_TIMEOUT_SECONDS=30
# PRISMA_CONNECT_TIMEOUT_SECONDS=10
# 经验建议：
# - 单实例连接池上限 ≈ (数据库 max_connections - 预留运维连接) / 应用实例数
# - 若压测期间频繁出现 pool timeout，可逐步上调并同步观察数据库 CPU / active connections
# 分佣计算队列并发（单进程 worker 并行度）
# CALC_COMMISSION_CONCURRENCY=4

# 应用配置
APP_PORT=8080
APP_PREFIX=/api
# 开发态 OpenAPI：默认仅当 controller/dto/vo 变更时重新执行 SwaggerModule.createDocument；
# 改 service 等业务代码不会触发全量扫描。强制刷新：OPENAPI_FORCE_REFRESH=true
# OPENAPI_FORCE_REFRESH=true
# 全局 HTTP 限流（express-rate-limit 后备限流）
# GLOBAL_RATE_LIMIT_WINDOW_MS=900000
# GLOBAL_RATE_LIMIT_MAX=5000
# Nest Throttler 全局限流（APP_GUARD 生效）
# THROTTLER_TTL_MS=60000
# THROTTLER_LIMIT=3000
# LOG_DIR=../logs

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=2
# REDIS_KEY_PREFIX=nest-admin-soybean:

# 高德 Web 服务 Key：https://console.amap.com/dev/key/app
# 用于 C 端收货地址地理编码、逆地理编码（坐标转展示地址）；不配置则地址仍可保存但不自动补坐标，小程序顶栏仅显示租户名
# AMAP_WEB_SERVICE_KEY=

# JWT 配置
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=2h

# 营销活动上下文 token 签名密钥（32+ 字符随机串；轮换时把旧 primary 临时放入 secondary）
MARKETING_ACTIVITY_TOKEN_SECRET_PRIMARY=change_me_marketing_activity_token_secret_32_chars
# MARKETING_ACTIVITY_TOKEN_SECRET_SECONDARY=
# MARKETING_ACTIVITY_TOKEN_TTL_SECONDS=86400

# OpenAI（AI 文案生成，OpenaiService 读取 OPENAI_API_KEY / OPENAI_BASE_URL）
# 密钥：https://platform.openai.com/api-keys
OPENAI_API_KEY=
# 对话模型（默认 gpt-5.4，与 OpenAI 控制台模型名一致即可）
# OPENAI_MODEL=gpt-5.4
# 可选：中转或兼容 OpenAI 的 Base URL；不填则使用 SDK 默认官方地址
# OPENAI_BASE_URL=
# 可选：请求超时毫秒数（默认 30000）；直连官方在国内易超时，可改为 60000～120000 或使用可用 BASE_URL
# OPENAI_TIMEOUT_MS=60000

# 文件上传
# 本地存储：FILE_IS_LOCAL=true（开发默认），文件落在 FILE_UPLOAD_LOCATION，经 FILE_DOMAIN + FILE_SERVE_ROOT 访问，不会上传 OSS
# 阿里云 OSS：FILE_IS_LOCAL=false 且填全 OSS_* 后重启后端，上传才会进入 Bucket
FILE_IS_LOCAL=true
FILE_UPLOAD_LOCATION=../upload
FILE_MAX_SIZE=10
FILE_DOMAIN=http://localhost:8080
FILE_SERVE_ROOT=/profile

# ========================================
# 阿里云 OSS（可选，与本地存储二选一）
# ========================================
# RAM 子用户：https://ram.console.aliyun.com/manage/ak
# 控制台访问端口 / Endpoint 说明：https://oss.console.aliyun.com/
# OSS_ACCESS_KEY_ID=你的AccessKeyId
# OSS_ACCESS_KEY_SECRET=你的AccessKeySecret
# RAM 须授权该密钥对应用户对当前 Bucket 的 oss:PutObject，否则报错 bucket acl / no right to access
# 地域，如北京：oss-cn-beijing（与控制台「地域节点」一致）
# OSS_REGION=oss-cn-beijing
# Bucket 名称
# OSS_BUCKET=your-bucket-name
# 访问用 Endpoint（仅主机名，不要带 https://）
# 外网（本机、非阿里云）：oss-cn-beijing.aliyuncs.com
# 同地域 ECS 内网：oss-cn-beijing-internal.aliyuncs.com
# OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# 对外访问文件的完整根 URL（须 HTTPS，末尾不要 /）
# 可用 Bucket 域名：https://your-bucket-name.oss-cn-beijing.aliyuncs.com
# 或已绑定证书与 CNAME 的自定义域名：https://files.example.com
# OSS_PUBLIC_BASE_URL=https://your-bucket-name.oss-cn-beijing.aliyuncs.com
# 对象键统一前缀，可留空；建议如 uploads/ 或 环境名/
# OSS_PREFIX=uploads/

# 腾讯云 COS（可选）
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=
# COS_DOMAIN=
# COS_LOCATION=

# 白名单（可选，JSON 字符串）
# PERM_WHITELIST=[{"path":"/captchaImage","method":"GET"}]

# 代码生成器（可选）
# GEN_AUTHOR=hqh-dot-wj
# GEN_PACKAGE_NAME=system
# GEN_MODULE_NAME=system
# GEN_AUTO_REMOVE_PRE=false
# GEN_TABLE_PREFIX=sys_

# 用户配置
USER_INITIAL_PASSWORD=123456

# 多租户配置
# TENANT_ENABLED: 是否启用多租户功能 (true=启用, false=禁用)
# - true: 启用多租户，所有数据按 tenantId 隔离
# - false: 禁用多租户，系统以单租户模式运行
TENANT_ENABLED=true
TENANT_SUPER_ID=000000
TENANT_DEFAULT_ID=000000
# 第三方回调等无法在 Header 带 tenant-id 的路径前缀（去掉 APP_PREFIX 后），英文逗号分隔，可选
# TENANT_EXEMPT_PATH_PREFIXES=/integrations/foo,/payment/callback/bar

# 加密配置（开发环境默认关闭，生产环境建议开启）
# 运行 pnpm generate:keys 生成密钥并自动更新配置
CRYPTO_ENABLED=true
CRYPTO_RSA_PUBLIC_
