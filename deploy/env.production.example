# 复制到服务器部署目录为 .env（例如 /opt/nest-admin/.env）
# 与 deploy/docker-compose.prod.yml 同步到服务器后的 compose 配合使用
#
# 说明：前端子路径（/、/h5/、/admin/）写在 deploy/nginx 与镜像构建参数中，
# 不依赖本文件。本文件主要配置 api 容器（数据库、JWT、OSS 等）。

# ---------- 镜像（CI 写入 IMAGE_TAG，也可手动 pin）----------
REGISTRY_NAMESPACE=ghcr.io/your-github-user/nest-admin-soybean
IMAGE_TAG=latest

# ---------- Postgres（compose 内置库）----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=nest-admin-soybean

# ---------- Redis ----------
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=2

# ---------- 应用 ----------
APP_PORT=8080
APP_PREFIX=/api
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

TENANT_ENABLED=true
TENANT_SUPER_ID=000000
TENANT_DEFAULT_ID=000000

CRYPTO_ENABLED=true
# 运行 pnpm --filter @apps/backend generate:keys 后填入
CRYPTO_RSA_PUBLIC_KEY=
CRYPTO_RSA_PRIVATE_KEY=

FILE_IS_LOCAL=true
FILE_UPLOAD_LOCATION=upload
FILE_DOMAIN=http://your-server-ip-or-domain
FILE_SERVE_ROOT=/profile

MARKETING_ACTIVITY_TOKEN_SECRET_PRIMARY=change_me_32_chars_minimum_secret

# 网关对外端口（与 deploy/ci.env HTTP_PORT 一致）
HTTP_PORT=80
COMPOSE_NETWORK_NAME=nest_admin_net
