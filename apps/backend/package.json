    "@willsoto/nestjs-prometheus": "^6.0.2",
    "@xobj/core": "^1.3.2",
    "ali-oss": "^6.23.0",
    "archiver": "catalog:",
    "axios": "catalog:",
    "bcryptjs": "catalog:",
