{
  "$schema": "https://json.schemastore.org/swcrc",
  "exclude": ["src/metadata.ts"],
  "sourceMaps": true,
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "baseUrl": "./",
    "paths": {
      "src/*": ["src/*"],
      "@src/*": ["src/*"]
    },
    "target": "es2021",
    "keepClassNames": true
  },
  "module": {
    "type": "commonjs"
  },
  "minify": false
}
