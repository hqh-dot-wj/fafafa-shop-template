{
  "name": "@apps/admin-web",
  "type": "module",
  "version": "1.2.1",
  "private": true,
  "description": "基于 Vue3 + NestJS 的现代化企业级后台管理系统，集成了强大的权限管理和丰富的组件库。",
  "license": "MIT",
  "homepage": "https://github.com/hqh-dot-wj/O2O-Mall-project",
  "keywords": [
    "Nest-Admin-Soybean",
    "Vue3",
    "NestJS",
    "admin-template",
    "Vite7",
    "TypeScript",
    "naive-ui",
    "naive-ui-admin",
    "UnoCSS"
  ],
  "contributors": [
    "hqh-dot-wj"
  ],
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.5.0"
  },
  "scripts": {
    "build": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "build:test": "vite build --mode test",
    "cleanup": "sa cleanup",
    "commit": "sa git-commit",
    "commit:zh": "sa git-commit -l=zh-cn",
    "deploy:dev": "node scripts/deploy.cjs dev",
    "deploy:prod": "node scripts/deploy.cjs prod",
    "deploy:test": "node scripts/deploy.cjs test",
    "dev": "vite --mode development",
    "dev:prod": "vite --mode production",
    "dev:test": "vite --mode test",
    "format": "prettier --write .",
    "generate:elegant-routes": "tsx scripts/generate-elegant-routes.ts",
    "gen-route": "sa gen-route",
    "generate:menu-from-views": "node scripts/generate-menu-from-views.mjs store/distribution",
    "generate:route-tests": "node scripts/generate-route-tests.mjs",
    "generate:route-tests:full": "node scripts/generate-route-tests.mjs store/distribution --full",
    "lint": "node ./scripts/lint.mjs",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "release": "sa release",
    "test": "pnpm typecheck:tests && vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node ./scripts/playwright-e2e.mjs",
    "test:e2e:smoke": "node ./scripts/playwright-e2e.mjs --project=smoke",
    "test:e2e:ui": "node ./scripts/playwright-e2e.mjs --ui",
    "test:run": "vitest run",
    "typecheck": "node ./scripts/typecheck.mjs",
    "typecheck:tests": "pnpm generate:elegant-routes && vue-tsc --noEmit -p tsconfig.test.json --skipLibCheck --pretty false",
    "update-pkg": "sa update-pkg"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@better-scroll/core": "2.5.1",
    "@iconify/vue": "5.0.0",
