/// 积分规则配置表
model MktPointsRule {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id") @db.VarChar(20)

  // 消费积分规则
  orderPointsEnabled Boolean @default(true) @map("order_points_enabled")
  orderPointsRatio   Decimal @default(1) @map("order_points_ratio") @db.Decimal(10, 2) // 每消费N元获得M积分
  orderPointsBase    Decimal @default(1) @map("order_points_base") @db.Decimal(10, 2) // N元

  // 签到积分规则
  signinPointsEnabled Boolean @default(true) @map("signin_points_enabled")
  signinPointsAmount  Int     @default(10) @map("signin_points_amount")

  // 积分有效期
  pointsValidityEnabled Boolean @default(false) @map("points_validity_enabled")
  pointsValidityDays    Int?    @map("points_validity_days") // 积分有效天数，null表示永久有效

  // 积分抵扣规则
  pointsRedemptionEnabled Boolean @default(true) @map("points_redemption_enabled")
  pointsRedemptionRatio   Decimal @default(100) @map("points_redemption_ratio") @db.Decimal(10, 2) // 每N积分可抵扣M元
  pointsRedemptionBase    Decimal @default(1) @map("points_redemption_base") @db.Decimal(10, 2) // M元

  // 积分抵扣限制
  maxPointsPerOrder       Int? @map("max_points_per_order") // 单笔订单最多可使用积分数量
  maxDiscountPercentOrder Int? @map("max_discount_percent_order") // 单笔订单最多可抵扣百分比(1-100)

  // 系统开关
  systemEnabled Boolean @default(true) @map("system_enabled")

  // 审计字段
  createBy   String   @map("create_by") @db.VarChar(64)
  createTime DateTime @default(now()) @map("create_time")
  updateBy   String?  @map("update_by") @db.VarChar(64)
  updateTime DateTime @updatedAt @map("update_time")

  @@map("mkt_points_rule")
}

/// 积分账户表
model MktPointsAccount {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id") @db.VarChar(20)
  memberId String @map("member_id")

  // 积分余额
  totalPoints     Int @default(0) @map("total_points") // 总积分（累计获得）
  availablePoints Int @default(0) @map("available_points") // 可用积分
  frozenPoints    Int @default(0) @map("frozen_points") // 冻结积分
  usedPoints      Int @default(0) @map("used_points") // 已使用积分
  expiredPoints   Int @default(0) @map("expired_points") // 已过期积分

  // 乐观锁
  version Int @default(0)

  // 审计字段
  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  // 关联
  transactions       MktPointsTransaction[]
  lots               MktPointsLot[]
  freezeAllocations  MktPointsFreezeAllocation[]
  consumeAllocations MktPointsConsumeAllocation[]
  refundAllocations  MktPointsRefundAllocation[]

  @@unique([tenantId, memberId])
  @@index([tenantId, availablePoints])
  @@map("mkt_points_account")
}

/// 积分交易记录表
model MktPointsTransaction {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id") @db.VarChar(20)
  accountId String @map("account_id")
  memberId  String @map("member_id")

  // 交易信息
  type          PointsTransactionType
  amount        Int // 积分变动数量（正数为增加，负数为减少）
  balanceBefore Int                   @map("balance_before") // 交易前余额
  balanceAfter  Int                   @map("balance_after") // 交易后余额

  // 关联信息
  relatedId   String? @map("related_id") // 关联业务ID（订单ID、任务ID等）
  relatedType String? @map("related_type") @db.VarChar(50) // 关联业务类型

  // 有效期（用于过期扣减）
  expireTime DateTime? @map("expire_time")

  // 状态
  status PointsTransactionStatus @default(COMPLETED)

  // 备注
  remark String? @db.VarChar(500)

  // 审计字段
  createTime DateTime @default(now()) @map("create_time")

  // 关联
  account                       MktPointsAccount             @relation(fields: [accountId], references: [id])
  sourceLots                    MktPointsLot[]               @relation("PointsLotSourceTransaction")
  freezeAllocations             MktPointsFreezeAllocation[]  @relation("PointsFreezeTransaction")
  releaseFreezeAllocations      MktPointsFreezeAllocation[]  @relation("PointsReleaseFreezeTransaction")
  consumeAllocations            MktPointsConsumeAllocation[] @relation("PointsSpendTransaction")
  refundTransactions            MktPointsRefundAllocation[]  @relation("PointsRefundTransaction")
  refundSourceSpendTransactions MktPointsRefundAllocation[]  @relation("PointsRefundSourceSpendTransaction")
  sourceDebts                   MktPointsDebt[]              @relation("PointsDebtSourceTransaction")

  @@index([tenantId, memberId, createTime])
  @@index([accountId, type])
  @@index([relatedId])
  @@index([expireTime])
  @@map("mkt_points_transaction")
}

/// 积分批次表
model MktPointsLot {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id") @db.VarChar(20)
  accountId String @map("account_id")
  memberId  String @map("member_id")

  // 来源交易：历史迁移批次允许为空
  sourceTransactionId String?                @map("source_transaction_id")
  sourceType          PointsTransactionType? @map("source_type")

  // 批次数量
  totalAmount     Int @map("total_amount")
  availableAmount Int @default(0) @map("available_amount")
  frozenAmount    Int @default(0) @map("frozen_amount")
  consumedAmount  Int @default(0) @map("consumed_amount")
  expiredAmount   Int @default(0) @map("expired_amount")

  expireTime DateTime?       @map("expire_time")
  status     PointsLotStatus @default(ACTIVE)

  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  account                 MktPointsAccount             @relation(fields: [accountId], references: [id])
  sourceTransaction       MktPointsTransaction?        @relation("PointsLotSourceTransaction", fields: [sourceTransactionId], references: [id])
  freezeAllocations       MktPointsFreezeAllocation[]
  consumeAllocations      MktPointsConsumeAllocation[]
  refundSourceAllocations MktPointsRefundAllocation[]  @relation("PointsRefundSourceLot")
  refundTargetAllocations MktPointsRefundAllocation[]  @relation("PointsRefundTargetLot")

  @@index([tenantId, memberId, expireTime])
  @@index([accountId, status, expireTime])
  @@index([sourceTransactionId])
  @@map("mkt_points_lot")
}

/// 积分冻结分摊表
model MktPointsFreezeAllocation {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id") @db.VarChar(20)
  accountId String @map("account_id")
  memberId  String @map("member_id")

  freezeTransactionId  String  @map("freeze_transaction_id")
  releaseTransactionId String? @map("release_transaction_id")
  lotId                String  @map("lot_id")
  relatedId            String? @map("related_id")

  amount Int
  status PointsFreezeAllocationStatus @default(ACTIVE)

  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  account            MktPointsAccount             @relation(fields: [accountId], references: [id])
  lot                MktPointsLot                 @relation(fields: [lotId], references: [id])
  freezeTransaction  MktPointsTransaction         @relation("PointsFreezeTransaction", fields: [freezeTransactionId], references: [id])
  releaseTransaction MktPointsTransaction?        @relation("PointsReleaseFreezeTransaction", fields: [releaseTransactionId], references: [id])
  consumeAllocations MktPointsConsumeAllocation[]

  @@unique([freezeTransactionId, lotId])
  @@index([tenantId, memberId, relatedId])
  @@index([lotId, status])
  @@map("mkt_points_freeze_allocation")
}

/// 积分消费分摊表
model MktPointsConsumeAllocation {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id") @db.VarChar(20)
  accountId String @map("account_id")
  memberId  String @map("member_id")

  spendTransactionId       String  @map("spend_transaction_id")
  sourceFreezeAllocationId String? @map("source_freeze_allocation_id")
  lotId                    String  @map("lot_id")
  relatedId                String? @map("related_id")

  amount           Int
  refundableAmount Int                           @map("refundable_amount")
  status           PointsConsumeAllocationStatus @default(ACTIVE)

  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  account                MktPointsAccount            @relation(fields: [accountId], references: [id])
  lot                    MktPointsLot                @relation(fields: [lotId], references: [id])
  spendTransaction       MktPointsTransaction        @relation("PointsSpendTransaction", fields: [spendTransactionId], references: [id])
  sourceFreezeAllocation MktPointsFreezeAllocation?  @relation(fields: [sourceFreezeAllocationId], references: [id])
  refundAllocations      MktPointsRefundAllocation[]

  @@index([tenantId, memberId, relatedId])
  @@index([spendTransactionId])
  @@index([lotId, status])
  @@map("mkt_points_consume_allocation")
}

/// 积分退款分摊表
model MktPointsRefundAllocation {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id") @db.VarChar(20)
  accountId String @map("account_id")
  memberId  String @map("member_id")

  refundTransactionId       String  @map("refund_transaction_id")
  sourceSpendTransactionId  String? @map("source_spend_transaction_id")
  sourceConsumeAllocationId String? @map("source_consume_allocation_id")
  sourceLotId               String? @map("source_lot_id")
  targetLotId               String? @map("target_lot_id")
  relatedId                 String? @map("related_id")

  amount   Int
  strategy PointsRefundAllocationStrategy

  createTime DateTime @default(now()) @map("create_time")

  account                 MktPointsAccount            @relation(fields: [accountId], references: [id])
  refundTransaction       MktPointsTransaction        @relation("PointsRefundTransaction", fields: [refundTransactionId], references: [id])
  sourceSpendTransaction  MktPointsTransaction?       @relation("PointsRefundSourceSpendTransaction", fields: [sourceSpendTransactionId], references: [id])
  sourceConsumeAllocation MktPointsConsumeAllocation? @relation(fields: [sourceConsumeAllocationId], references: [id])
  sourceLot               MktPointsLot?               @relation("PointsRefundSourceLot", fields: [sourceLotId], references: [id])
  targetLot               MktPointsLot?               @relation("PointsRefundTargetLot", fields: [targetLotId], references: [id])

  @@index([tenantId, memberId, relatedId])
  @@index([refundTransactionId])
  @@index([sourceSpendTransactionId])
  @@index([sourceLotId])
  @@map("mkt_points_refund_allocation")
}

/// 积分欠账/风险记录
/// 用于记录退款扣回消费赠送积分时，账户余额不足导致的待补账事实。
model MktPointsDebt {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id") @db.VarChar(20)

  accountId String? @map("account_id")
  memberId  String  @map("member_id")

  sourceTransactionId String? @map("source_transaction_id")
  relatedId           String? @map("related_id")
  relatedType         String? @map("related_type") @db.VarChar(50)

  reason PointsDebtReason
  status PointsDebtStatus @default(OPEN)

  expectedAmount    Int @map("expected_amount")
  deductedAmount    Int @default(0) @map("deducted_amount")
  debtAmount        Int @map("debt_amount")
  availableAtCreate Int @default(0) @map("available_at_create")

  remark     String?  @db.VarChar(500)
  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  sourceTransaction MktPointsTransaction? @relation("PointsDebtSourceTransaction", fields: [sourceTransactionId], references: [id])

  @@unique([tenantId, memberId, relatedId, reason], map: "uk_mkt_points_debt_biz")
  @@index([tenantId, memberId, status])
  @@index([relatedId])
  @@index([sourceTransactionId])
  @@map("mkt_points_debt")
}

/// 积分任务配置表
model MktPointsTask {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id") @db.VarChar(20)

  // 任务信息
  taskKey         String  @map("task_key") @db.VarChar(50) // 任务唯一标识（如：COMPLETE_PROFILE）
  taskName        String  @map("task_name") @db.VarChar(100)
  taskDescription String? @map("task_description") @db.VarChar(500)

  // 积分奖励
  pointsReward Int @map("points_reward")

  // 完成条件
  completionCondition Json @map("completion_condition") // 完成条件配置（JSON格式）

  // 限制
  isRepeatable   Boolean @default(false) @map("is_repeatable") // 是否可重复完成
  maxCompletions Int?    @map("max_completions") // 最多完成次数

  // 状态
  isEnabled Boolean @default(true) @map("is_enabled")

  // 审计字段
  createBy   String   @map("create_by") @db.VarChar(64)
  createTime DateTime @default(now()) @map("create_time")
  updateBy   String?  @map("update_by") @db.VarChar(64)
  updateTime DateTime @updatedAt @map("update_time")

  @@unique([tenantId, taskKey])
  @@index([tenantId, isEnabled])
  @@map("mkt_points_task")
}

/// 用户任务完成记录表
model MktUserTaskCompletion {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id") @db.VarChar(20)
  memberId String @map("member_id")
  taskId   String @map("task_id")

  // 完成信息
  completionTime DateTime @default(now()) @map("completion_time")
  pointsAwarded  Int      @map("points_awarded")
  transactionId  String   @map("transaction_id") // 关联的积分交易记录ID

  @@index([tenantId, memberId, taskId])
  @@map("mkt_user_task_completion")
}

/// 积分发放失败记录表
model MktPointsGrantFailure {
  id       String @id @default(uuid())
  memberId String @map("member_id")

  // 积分信息
  amount     Int                   @map("amount")
  type       PointsTransactionType @map("type")
  relatedId  String?               @map("related_id")
  remark     String?               @db.VarChar(500)
  expireTime DateTime?             @map("expire_time")

  // 失败信息
  failureReason    String    @map("failure_reason") @db.VarChar(500)
  failureTime      DateTime  @map("failure_time")
  retryCount       Int       @default(0) @map("retry_count")
  lastRetryTime    DateTime? @map("last_retry_time")
  lastErrorMessage String?   @map("last_error_message") @db.VarChar(1000)

  // 状态: PENDING-待重试, COMPLETED-已完成, FAILED-最终失败
  status String @default("PENDING") @db.VarChar(20)

  // 审计字段
  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  @@index([memberId, status])
  @@index([relatedId])
  @@index([failureTime])
  @@map("mkt_points_grant_failure")
}

enum MktTouchpointKind {
  MESSAGE
  SHARE
}

enum MktCampaignStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum MktCampaignKind {
  POLICY
  HANDLER
}

enum MktCampaignReleaseStatus {
  PENDING
  PUBLISHED
  ROLLED_BACK
  ARCHIVED
}

enum MktEntitlementPoolType {
  PRODUCT
  COUPON
  POINTS
}

enum MktEntitlementPoolStatus {
  DRAFT
  COMPILED
  FAILED
}

model MktCampaign {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id") @db.VarChar(20)
  name            String            @db.VarChar(120)
  type            String            @db.VarChar(50)
  kind            MktCampaignKind   @default(POLICY)
  description     String?           @db.VarChar(500)
  status          MktCampaignStatus @default(DRAFT)
  startTime       DateTime?         @map("start_time")
  endTime         DateTime?         @map("end_time")
  priority        Int               @default(0)
  policyJson      Json?             @map("policy_json")
  foundationJson  Json?             @map("foundation_json")
  audienceJson    Json?             @map("audience_json")
  rightsJson      Json?             @map("rights_json")
  stagesJson      Json?             @map("stages_json")
  deliveryJson    Json?             @map("delivery_json")
  constraintsJson Json?             @map("constraints_json")
  ownerUserId     String?           @map("owner_user_id") @db.VarChar(64)
  version         Int               @default(1)
  createdBy       String?           @map("created_by") @db.VarChar(64)
  updatedBy       String?           @map("updated_by") @db.VarChar(64)
  createTime      DateTime          @default(now()) @map("create_time")
  updateTime      DateTime          @updatedAt @map("update_time")

  releases         MktCampaignRelease[]
  entitlementPools MktCampaignEntitlementPool[]
  participations   MktCampaignParticipation[]
  touchpoints      MktCampaignTouchpoint[]

  @@index([tenantId, type, status])
  @@index([tenantId, status, startTime, endTime])
  @@index([tenantId, updateTime])
  @@map("mkt_campaign")
}

model MktCampaignRelease {
  id                  String                   @id @default(cuid())
  tenantId            String                   @map("tenant_id") @db.VarChar(20)
  campaignId          String                   @map("campaign_id")
  releaseNo           Int                      @default(1) @map("release_no")
  status              MktCampaignReleaseStatus @default(PENDING)
  snapshotJson        Json                     @map("snapshot_json")
  entitlementSnapshot Json?                    @map("entitlement_snapshot")
  publishedAt         DateTime?                @map("published_at")
  createdBy           String?                  @map("created_by") @db.VarChar(64)
  updatedBy           String?                  @map("updated_by") @db.VarChar(64)
  createTime          DateTime                 @default(now()) @map("create_time")
  updateTime          DateTime                 @updatedAt @map("update_time")

  campaign MktCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([tenantId, campaignId, releaseNo])
  @@index([tenantId, status])
  @@map("mkt_campaign_release")
}

model MktEntitlementPool {
  id                   String                   @id @default(cuid())
  tenantId             String                   @map("tenant_id") @db.VarChar(20)
  name                 String                   @db.VarChar(120)
  poolType             MktEntitlementPoolType   @map("pool_type")
  status               MktEntitlementPoolStatus @default(DRAFT)
  owner                String?                  @db.VarChar(128)
  touchpoints          Json                     @default("[]")
  sourceType           String?                  @map("source_type") @db.VarChar(30)
  sourceKey            String?                  @map("source_key") @db.VarChar(120)
  memberId             String?                  @map("member_id") @db.VarChar(64)
  templateId           String?                  @map("template_id") @db.VarChar(64)
  templateName         String?                  @map("template_name") @db.VarChar(120)
  taskId               String?                  @map("task_id") @db.VarChar(64)
  taskName             String?                  @map("task_name") @db.VarChar(120)
  compilePreviewJson   Json?                    @map("compile_preview_json")
  riskSummaryJson      Json?                    @map("risk_summary_json")
  compileArtifactsJson Json?                    @map("compile_artifacts_json")
  lastCompiledAt       DateTime?                @map("last_compiled_at")
  createdBy            String?                  @map("created_by") @db.VarChar(64)
  updatedBy            String?                  @map("updated_by") @db.VarChar(64)
  createTime           DateTime                 @default(now()) @map("create_time")
  updateTime           DateTime                 @updatedAt @map("update_time")

  campaignRelations MktCampaignEntitlementPool[]

  @@index([tenantId, poolType])
  @@index([tenantId, status])
  @@index([tenantId, updateTime])
  @@map("mkt_entitlement_pool")
}

model MktCampaignEntitlementPool {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id") @db.VarChar(20)
  campaignId String   @map("campaign_id")
  poolId     String   @map("pool_id")
  sortOrder  Int      @default(0) @map("sort_order")
  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  campaign MktCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  pool     MktEntitlementPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([tenantId, campaignId, poolId])
  @@index([tenantId, campaignId])
  @@index([tenantId, poolId])
  @@map("mkt_campaign_entitlement_pool")
}

model MktCampaignTouchpoint {
  id         String            @id @default(cuid())
  tenantId   String            @map("tenant_id") @db.VarChar(20)
  campaignId String            @map("campaign_id")
  kind       MktTouchpointKind @map("kind")
  code       String            @db.VarChar(60)
  name       String            @db.VarChar(100)
  config     Json
  isEnabled  Boolean           @default(true) @map("is_enabled")
  createTime DateTime          @default(now()) @map("create_time")
  updateTime DateTime          @updatedAt @map("update_time")

  campaign MktCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([tenantId, campaignId, kind, code])
  @@index([tenantId, campaignId, kind])
  @@map("mkt_campaign_touchpoint")
}

model MktCampaignParticipation {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id") @db.VarChar(20)
  campaignId String @map("campaign_id")
  memberId   String @map("member_id")

  rewardsSnapshot Json? @map("rewards_snapshot")

  createTime DateTime @default(now()) @map("create_time")

  campaign MktCampaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, memberId])
  @@index([tenantId, memberId])
  @@map("mkt_campaign_participation")
}

model MktSceneTemplate {
  id                        String                   @id @default(cuid())
  templateCode              String                   @unique @map("template_code") @db.VarChar(60)
  templateName              String                   @map("template_name") @db.VarChar(120)
  sceneType                 String                   @map("scene_type") @db.VarChar(40)
  channelScope              Json                     @map("channel_scope")
  pageRoute                 String?                  @map("page_route")
  defaultCardTemplateCode   String?                  @map("default_card_template_code")
  defaultResolverPolicyCode String?                  @map("default_resolver_policy_code")
  placementConfig           Json?                    @map("placement_config")
  description               String?                  @db.VarChar(500)
  isActive                  Boolean                  @default(true) @map("is_active")
  createTime                DateTime                 @default(now()) @map("create_time")
  updateTime                DateTime                 @updatedAt @map("update_time")
  modules                   MktSceneTemplateModule[]
  scenes                    MktScene[]

  @@index([isActive])
  @@map("mkt_scene_template")
}

model MktSceneTemplateModule {
  id                    String           @id @default(cuid())
  templateCode          String           @map("template_code") @db.VarChar(60)
  moduleSlot            String           @map("module_slot") @db.VarChar(60)
  moduleName            String           @map("module_name")
  moduleType            String           @map("module_type")
  title                 String?          @map("title")
  subTitle              String?          @map("sub_title")
  displayOrder          Int              @default(0) @map("display_order")
  limitSize             Int              @default(20) @map("limit_size")
  sourcePolicyCode      String           @map("source_policy_code")
  resolverPolicyCode    String           @map("resolver_policy_code")
  sortPolicyCode        String?          @map("sort_policy_code")
  audiencePolicyCode    String?          @map("audience_policy_code")
  cardTemplateCode      String           @map("card_template_code")
  attributionPolicyCode String?          @map("attribution_policy_code")
  uiConfig              Json?            @map("ui_config")
  template              MktSceneTemplate @relation(fields: [templateCode], references: [templateCode], onDelete: Cascade)

  @@unique([templateCode, moduleSlot])
  @@map("mkt_scene_template_module")
}

model MktScene {
  id                        String            @id @default(cuid())
  tenantId                  String            @map("tenant_id") @db.VarChar(20)
  sceneCode                 String            @map("scene_code")
  sceneName                 String            @map("scene_name")
  sceneType                 String            @map("scene_type")
  channelScope              Json              @map("channel_scope")
  pageRoute                 String?           @map("page_route")
  defaultCardTemplateCode   String?           @map("default_card_template_code")
  defaultResolverPolicyCode String?           @map("default_resolver_policy_code")
  /// 场景投放展示配置：activityTypeFilter / storeMatchMode / sortMode 等（与 admin 场景定义页对齐）
  placementConfig           Json?             @map("placement_config")
  templateCode              String?           @map("template_code") @db.VarChar(60)
  templateOverrides         Json?             @map("template_overrides")
  status                    String
  startAt                   DateTime?         @map("start_at")
  endAt                     DateTime?         @map("end_at")
  createTime                DateTime          @default(now()) @map("create_time")
  updateTime                DateTime          @updatedAt @map("update_time")
  modules                   MktSceneModule[]
  releases                  MktSceneRelease[]
  template                  MktSceneTemplate? @relation(fields: [templateCode], references: [templateCode])

  @@unique([tenantId, sceneCode])
  @@index([tenantId, status])
  @@index([templateCode])
  @@map("mkt_scene")
}

model MktSceneModule {
  id                    String    @id @default(cuid())
  tenantId              String    @map("tenant_id") @db.VarChar(20)
  sceneCode             String    @map("scene_code")
  moduleCode            String    @map("module_code")
  moduleName            String    @map("module_name")
  moduleType            String    @map("module_type")
  title                 String?   @map("title")
  subTitle              String?   @map("sub_title")
  displayOrder          Int       @default(0) @map("display_order")
  limitSize             Int       @default(20) @map("limit_size")
  sourcePolicyCode      String    @map("source_policy_code")
  resolverPolicyCode    String    @map("resolver_policy_code")
  sortPolicyCode        String?   @map("sort_policy_code")
  audiencePolicyCode    String?   @map("audience_policy_code")
  cardTemplateCode      String    @map("card_template_code")
  attributionPolicyCode String?   @map("attribution_policy_code")
  uiConfig              Json?     @map("ui_config")
  status                String
  startAt               DateTime? @map("start_at")
  endAt                 DateTime? @map("end_at")
  createTime            DateTime  @default(now()) @map("create_time")
  updateTime            DateTime  @updatedAt @map("update_time")
  scene                 MktScene  @relation(fields: [sceneCode, tenantId], references: [sceneCode, tenantId])

  @@unique([tenantId, moduleCode])
  @@index([tenantId, sceneCode, displayOrder])
  @@map("mkt_scene_module")
}

model MktSceneRelease {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id") @db.VarChar(20)
  sceneCode       String    @map("scene_code")
  releaseNo       Int       @map("release_no")
  releaseStatus   String    @map("release_status")
  releaseSnapshot Json      @map("release_snapshot")
  publishedBy     String?   @map("published_by")
  publishedAt     DateTime? @map("published_at")
  createTime      DateTime  @default(now()) @map("create_time")
  scene           MktScene  @relation(fields: [sceneCode, tenantId], references: [sceneCode, tenantId])

  @@unique([tenantId, sceneCode, releaseNo])
  @@index([tenantId, sceneCode, releaseStatus])
  @@map("mkt_scene_release")
}

model MktPolicy {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id") @db.VarChar(20)
  policyCode String   @map("policy_code")
  policyName String   @map("policy_name")
  policyType String   @map("policy_type")
  config     Json
  status     String   @default("ACTIVE")
  createTime DateTime @default(now()) @map("create_time")
  updateTime DateTime @updatedAt @map("update_time")

  @@unique([tenantId, policyCode])
  @@index([tenantId, policyType, status])
  @@map("mkt_policy")
}

model OmsOrderItemAttribution {
  id                         BigInt  @id @default(autoincrement())
  orderItemId                Int     @unique @map("order_item_id")
  tenantId                   String  @map("tenant_id")
  sourceSceneCodeSnapshot    String? @map("source_scene_code_snapshot")
  sourceModuleCodeSnapshot   String? @map("source_module_code_snapshot")
  sourceChannelSnapshot      String? @map("source_channel_snapshot")
  sourcePagePathSnapshot     String? @map("source_page_path_snapshot")
  shareUserIdSnapshot        String? @map("share_user_id_snapshot")
  referrerIdSnapshot         String? @map("referrer_id_snapshot")
  cardTemplateCodeSnapshot   String? @map("card_template_code_snapshot")
  resolverPolicyCodeSnapshot String? @map("resolver_policy_code_snapshot")
  resolverReleaseNoSnapshot  Int?    @map("resolver_release_no_snapshot")
  audienceSnapshot           Json?   @map("audience_snapshot")
  secondaryBenefitsSnapshot  Json?   @map("secondary_benefits_snapshot")
  denyStackReasonsSnapshot   Json?   @map("deny_stack_reasons_snapshot")
  entryContextSnapshot       Json?   @map("entry_context_snapshot")

  @@index([tenantId, sourceSceneCodeSnapshot])
  @@map("oms_order_item_attribution")
}

model RptOrderItemMarketingFact {
  id               BigInt  @id @default(autoincrement())
  tenantId         String  @map("tenant_id")
  orderItemId      Int     @unique @map("order_item_id")
  sourceSceneCode  String? @map("source_scene_code")
  sourceModuleCode String? @map("source_module_code")
  primaryOfferType String? @map("primary_offer_type")
  finalPaidAmount  Decimal @map("final_paid_amount") @db.Decimal(10, 2)

  @@index([tenantId, sourceSceneCode, sourceModuleCode])
  @@map("rpt_order_item_marketing_fact")
}
