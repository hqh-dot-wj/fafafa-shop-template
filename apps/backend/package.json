    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.0",
    "lodash": "catalog:",
    "mime-types": "^2.1.35",
    "nestjs-cls": "^6.1.0",
    "nestjs-pino": "^4.5.0",
    "node-forge": "^1.3.3",
    "openai": "^6.33.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
