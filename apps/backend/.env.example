# 微信多端配置
# 商城小程序（C端消费者），未配置时 fallback 到 WX_APPID/WX_SECRET
# WX_MP_MALL_APPID=
# WX_MP_MALL_SECRET=

# 师傅小程序（Worker端）
# WX_MP_WORK_APPID=
# WX_MP_WORK_SECRET=

# H5 网页端（微信公众号/开放平台网页授权）
# WX_H5_APPID=
# WX_H5_SECRET=

# 客户端配置
CLIENT_DEFAULT_ID=pc
CLIENT_DEFAULT_GRANT_TYPE=password
# C端商品查询限流（每分钟，按用户或IP）
# CLIENT_PRODUCT_LIST_RATE_LIMIT=300
# CLIENT_PRODUCT_DETAIL_RATE_LIMIT=500
# CLIENT_PRODUCT_CATEGORY_RATE_LIMIT=240
# 后台店铺商品限流（每分钟，按租户+用户）
# ADMIN_STORE_PRODUCT_LIST_RATE_LIMIT=1200
# ADMIN_STORE_PRODUCT_IMPORT_EXCEL_RATE_LIMIT=1200
# ADMIN_STORE_PRODUCT_IMPORT_BATCH_RATE_LIMIT=600
# 后台商品导入异步队列（worker 并发 / 单任务最大行数 / base64 最大字符数）
# ADMIN_STORE_PRODUCT_IMPORT_WORKER_CONCURRENCY=4
# ADMIN_STORE_PRODUCT_IMPORT_MAX_ROWS=500
# ADMIN_STORE_PRODUCT_IMPORT_MAX_FILE_BASE64_CHARS=12000000
# ADMIN_STORE_PRODUCT_IMPORT_QUEUE_BACKLOG_LIMIT=5000
# 后台商品查询限流命中兜底（返回短期陈旧缓存，降低 429）
# ADMIN_STORE_PRODUCT_LIST_RATE_LIMIT_FALLBACK_ENABLED=true
# ADMIN_STORE_PRODUCT_LIST_FALLBACK_TTL_MS=30000
# 后台商品查询主缓存（L2 + L1）
# ADMIN_STORE_PRODUCT_LIST_QUERY_CACHE_ENABLED=true
# ADMIN_STORE_PRODUCT_LIST_QUERY_CACHE_TTL_SECONDS=60
# ADMIN_STORE_PRODUCT_LIST_QUERY_STALE_TTL_SECONDS=1800
# ADMIN_STORE_PRODUCT_LIST_QUERY_L1_TTL_MS=3000
# ADMIN_STORE_PRODUCT_LIST_QUERY_L1_MAX_ENTRIES=2000
# 单实例商品查询并发舱壁（保护数据库）；建议按压测结果从 200~800 逐步调优
# CLIENT_PRODUCT_LIST_INFLIGHT_LIMIT=400
# 商品查询限流命中时是否优先返回陈旧缓存（true=优先兜底返回200，false=直接429）
# CLIENT_PRODUCT_RATE_LIMIT_FALLBACK_ENABLED=true
# 商品查询过载时是否优先走陈旧缓存兜底（true=优先兜底返回200，false=直接429）
# CLIENT_PRODUCT_LIST_OVERLOAD_FALLBACK_ENABLED=true

# ========================================
# 微信支付配置
# ========================================
# 获取方式：登录微信商户平台 https://pay.weixin.qq.com/
# - AppId: 小程序 AppId（微信公众平台获取）
# - 商户号: 商户平台 → 账户中心 → 商户信息
# - API 密钥: 商户平台 → 账户中心 → API 安全 → 设置密钥（API v2，32位）
# - API v3 密钥: 商户平台 → 账户中心 → API 安全 → 设置 APIv3 密钥（32位）
# - 证书序列号: 商户平台 → 账户中心 → API 安全 → 查看证书
# - 私钥: 商户平台 → 账户中心 → API 安全 → 下载证书（apiclient_key.pem）
# 测试环境：使用微信支付沙箱 https://pay.weixin.qq.com/wiki/doc/api/jsapi.php?chapter=23_1

# 小程序 AppId
WECHAT_PAY_APP_ID=wx1234567890abcdef

# 商户号
WECHAT_PAY_MCH_ID=1234567890

# API 密钥（API v2，用于签名验证）
WECHAT_PAY_API_KEY=your_32_character_api_key_here

# API v3 密钥（用于 API v3 接口加密）
WECHAT_PAY_API_V3_KEY=your_32_character_api_v3_key_here

# 商户证书序列号
WECHAT_PAY_SERIAL_NO=your_certificate_serial_number

# 商户私钥路径（相对于项目根目录或绝对路径）
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem

# 支付回调通知 URL（需要公网可访问）
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/client/payment/notify

# 退款回调通知 URL（需要公网可访问）
WECHAT_PAY_REFUND_NOTIFY_URL=https://your-domain.com/api/payment/refund-notify

# 是否启用沙箱环境（true=沙箱，false=生产）
WECHAT_PAY_SANDBOX=false

# 支付网关模式（auto=生产微信/非生产mock，wechat=强制微信，mock=强制mock）
PAYMENT_GATEWAY_MODE=auto

# 是否允许调用 client/payment/mock-success（生产建议 false）
PAYMENT_ENABLE_MOCK_SUCCESS=false

# 是否校验微信支付回调签名（生产必须 true，开发联调可 false）
WECHAT_PAY_CALLBACK_VERIFY_SIGNATURE=true
